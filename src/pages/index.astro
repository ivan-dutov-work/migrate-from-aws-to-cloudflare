---
/**
 * If PUBLIC_CDN_URL is set (e.g. https://<bucket>.r2.dev/gallery)
 * images load from the CDN. Otherwise they fall back to the local
 * /gallery/ path served from the public/ directory.
 */
const TOTAL_IMAGES = 100;
const cdnBase = import.meta.env.PUBLIC_CDN_URL; // optional
const base = cdnBase ? cdnBase.replace(/\/+$/, "") : "/gallery";

const images = Array.from({ length: TOTAL_IMAGES }, (_, i) => ({
  src: `${base}/photo-${i + 1}.jpg`,
  alt: `Architectural photograph ${i + 1}`,
}));
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Gallery</title>

    <style>
      /* ── Reset & Base ───────────────────────────────── */
      *,
      *::before,
      *::after {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html {
        font-family:
          "Segoe UI",
          system-ui,
          -apple-system,
          sans-serif;
        background: #0e0e0e;
        color: #e0e0e0;
      }

      /* ── Header ─────────────────────────────────────── */
      header {
        position: sticky;
        top: 0;
        z-index: 10;
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        padding: 1.25rem 2rem;
        background: rgba(14, 14, 14, 0.85);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid rgba(255, 255, 255, 0.06);
      }

      header h1 {
        font-size: 1.35rem;
        font-weight: 600;
        letter-spacing: 0.04em;
        color: #ffffff;
      }

      header span {
        font-size: 0.85rem;
        color: #888;
        font-weight: 400;
      }

      /* ── Gallery Masonry ────────────────────────────── */
      .gallery {
        padding: 1.5rem;
        column-count: 4;
        column-gap: 1rem;
      }

      .gallery img {
        width: 100%;
        display: block;
        margin-bottom: 1rem;
        border-radius: 4px;
        break-inside: avoid;
      }

      /* ── Responsive breakpoints ─────────────────────── */
      @media (max-width: 1200px) {
        .gallery {
          column-count: 3;
        }
      }

      @media (max-width: 800px) {
        .gallery {
          column-count: 2;
          padding: 0.75rem;
        }
        header {
          padding: 1rem 1.25rem;
        }
      }

      @media (max-width: 480px) {
        .gallery {
          column-count: 1;
        }
      }
    </style>
  </head>

  <body>
    <header>
      <h1>Gallery</h1>
      <span>{images.length} photographs</span>
    </header>

    <main class="gallery">
      {
        images.map((img) => (
          <img src={img.src} alt={img.alt} loading="lazy" decoding="async" />
        ))
      }
    </main>
  </body>
</html>
